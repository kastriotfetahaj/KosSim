{
    admin unix//var/run/caddy.sock {
        # "caddy" for curl, ip for caddy-cli
        origins "127.0.0.1" "caddy"
    }
    log default {
        output stdout
        level INFO
        format json {
            time_format "2006-01-02T15:04:05.000"
            duration_format nano
        }
    }
    servers {
        trusted_proxies static 10.20.57.10/32
    }
}

(hsts) {
    header /* {
        Strict-Transport-Security "max-age=6307200; includeSubdomains; preload;"
    }
}

http://{$HOST_NAME} {

    log

    import hsts

    header /* {
        Content-Security-Policy "script-src 'self' https://hcaptcha.com 'sha256-YS9p0l7SQLkAEtvGFGffDcYHRcUBpPzMcbSQe1lRuLc='; object-src 'none'; frame-ancestors 'none'"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy: "no-referrer"
        Permissions-Policy: "accelerometer=(), ambient-light-sensor=(), autoplay=(), battery=(), camera=(), cross-origin-isolated=(), display-capture=(), document-domain=(), encrypted-media=(), execution-while-not-rendered=(), execution-while-out-of-viewport=(), fullscreen=(), geolocation=(), gyroscope=(), keyboard-map=(), magnetometer=(), microphone=(), midi=(), payment=(), picture-in-picture=(), publickey-credentials-get=(), screen-wake-lock=(), usb=(), xr-spatial-tracking=()"
    }

    handle_path /static* {
        root * /srv/static
        header Cache-Control max-age=1800

        header /vm/* {
            Content-Disposition attachment;
        }

        header /old/* {
            Content-Security-Policy "script-src 'self' 'unsafe-inline'; object-src 'none'; frame-ancestors 'none'; script-src-attr 'unsafe-inline'"
        }

        file_server {
            disable_canonical_uris
        }
    }


    request_body /* {
        max_size 10MB
    }

    reverse_proxy http://localhost:8000 {
        header_up X-Request-Id {http.request.uuid}

        # Strip Authorization header to prevent confusion on rest-api endpoints
        header_up -Authorization
    }
}

http://images.{$HOST_NAME} {

    log

    import hsts

    header /* {
        Content-Security-Policy "default-src: none;"
    }

    handle_path /media/* {
        root * /srv/uploads
        header Cache-Control max-age=1800
        file_server {
            disable_canonical_uris
        }
    }
}
