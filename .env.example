POSTGRES_PASSWORD=replace-with-strong-database-password
SERVICE_PUSH_SECRET=replace-with-strong-service-secret
SECRET_FLAG_KEY=replace-with-strong-flag-hmac-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-admin-password
ADMIN_SESSION_SECRET=replace-with-strong-session-secret
GAME_ADMIN_TOKEN=replace-with-strong-admin-api-token

# Optional local overrides
ROTATION_SECONDS=120
FLAG_RETENTION_TICKS=5
CHECKER_CONCURRENCY=8
CHECKER_MAX_ATTEMPTS=2
CHECKER_RETRY_DELAY_SECONDS=3
SERVICE_HTTP_TIMEOUT=3.0
SERVICE_CHECK_BUDGET_SECONDS=25
CHECKER_NOISE_ENABLED=1
CHECKER_HAVOC_ENABLED=1
CHALLENGE_DATA_ROOT=/var/lib

# Distributed workers / routing defaults
CHECKER_WORKER_CONCURRENCY=4
CHECKER_CIDR=10.32.250.0/24
CONTROL_PUBLIC_CIDR=10.32.251.2/32
CONTROL_PUBLIC_PORTS=80,443,1337
ROUTER_WG_ENDPOINT=router-public-ip:51820
ROUTER_WG_PORT=51820
VULNBOX_COMPOSE_BIN=docker compose
VULNBOX_COMPOSE_FILE=/workspace/docker-compose.yml
VULNBOX_COMPOSE_PROJECT=kossim
