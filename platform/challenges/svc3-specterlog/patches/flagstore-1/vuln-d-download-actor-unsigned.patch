Subject: bind actor into the signed-download HMAC payload

signDownload omits actor from the body it HMACs, but the attachment
handler reads actor from the unsigned querystring and serves the raw blob
when actor=admin. Anyone holding a public-actor signed URL can flip actor
without invalidating the signature. Include actor in the signed payload
and in the verifier, and thread it through the share-mint endpoint and
the flagstore PUTFLAG dispatch so the checker's HAVOC v3 (which mints a
fresh admin URL via /share) and PUTFLAG v1 (which mints the public-actor
URL surfaced as attack-info) both continue to round-trip.

--- a/service/src/tokens.ts
+++ b/service/src/tokens.ts
@@ -37,10 +37,11 @@
 export type DownloadClaim = {
   case_id: string;
   handle: string;
   exp: number;
+  actor: string;
 };

 export function signDownload(secret: string, claim: DownloadClaim): string {
-  const body = `${claim.case_id}|${claim.handle}|${claim.exp}`;
+  const body = `${claim.case_id}|${claim.handle}|${claim.exp}|${claim.actor}`;
   return createHmac("sha256", secret).update(body).digest("hex");
 }

